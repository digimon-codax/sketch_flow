# Copy this to server/.env and fill in your values

PORT=3001
NODE_ENV=development

# MongoDB
# Local Docker:  mongodb://localhost:27017/sketchflow
# Atlas Cloud:   mongodb+srv://user:pass@cluster.mongodb.net/sketchflow
MONGO_URI=mongodb://localhost:27017/sketchflow

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-string

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# AWS S3 (optional — leave blank to use local disk)
AWS_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
