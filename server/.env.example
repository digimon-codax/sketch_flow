# SketchFlow Server Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# MongoDB (matches docker-compose defaults)
DATABASE_URL="mongodb://localhost:27017/sketchflow?replicaSet=rs0"

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# AWS S3 (optional — uses local disk storage if not set)
AWS_BUCKET=sketchflow-files
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
